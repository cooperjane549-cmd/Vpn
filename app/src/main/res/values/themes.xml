<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 1. The Main App Theme (Post-Splash) -->
    <!-- Renamed to Theme.SweetDataVPN to stop the circular crash -->
    <style name="Theme.SweetDataVPN" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Brand Colors -->
        <item name="colorPrimary">#FF0033</item>
        <item name="colorOnPrimary">#FFFFFF</item> <!-- FIX: Makes button text/icons WHITE -->
        <item name="android:statusBarColor">#090909</item>
        
        <!-- FIX: Forces buttons to show the Red color clearly -->
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button</item>

        <!-- Essential Material Settings -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- 2. The Starting/Splash Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/app_logo</item>
        <item name="windowSplashScreenBackground">#090909</item>
        <!-- 3. Points to the correct Main Theme above -->
        <item name="postSplashScreenTheme">@style/Theme.SweetDataVPN</item>
    </style>
</resources>
