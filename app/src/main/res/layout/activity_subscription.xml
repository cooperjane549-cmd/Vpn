<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PREMIUM ACCESS"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unlimited VPN for 24 Hours"
            android:layout_marginTop="4dp"
            android:textColor="?android:attr/textColorSecondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kes 30 / $0.25"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMpesaInstructions"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="PAY VIA M-PESA (TILL: 3043489)"
            android:backgroundTint="?attr/colorPrimary"
            android:layout_marginTop="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPaypalLink"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="PAY VIA PAYPAL"
            android:backgroundTint="?attr/colorSecondary"
            android:layout_marginTop="12dp" />

        <View 
            android:layout_width="match_parent" 
            android:layout_height="1dp" 
            android:background="#333333" 
            android:layout_marginVertical="30dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SUBMIT PAYMENT PROOF"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary" />

        <EditText
            android:id="@+id/etMpesaMessage"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="Paste M-Pesa or PayPal confirmation message here..."
            android:gravity="top"
            android:padding="12dp"
            android:textColor="?android:attr/textColorPrimary"
            android:background="?attr/editTextBackground"
            android:layout_marginTop="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitPayment"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SUBMIT FOR VERIFICATION"
            android:layout_marginTop="16dp"
            android:backgroundTint="?attr/colorPrimary" />

    </LinearLayout>
</ScrollView>
