<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#090909">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIP &amp; REWARDS"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- Referral Section (Untouched) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Invite Friends (Earn 50MB)"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvReferralCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Code: LOADING..."
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="5dp"/>
                <Button
                    android:id="@+id/btnShareReferral"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SHARE ON WHATSAPP"
                    android:layout_marginTop="10dp"
                    app:backgroundTint="#25D366"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- PayPal Section (Untouched) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPaypal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Global VIP (PayPal)"
                    android:textColor="#0070BA"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unlimited High Speed - $5/Month"
                    android:textColor="#9CA3AF"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- M-Pesa Info Section (Untouched) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMpesa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="M-Pesa (Kenya)"
                    android:textColor="#22C55E"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Till: 3043489 - KSh 500/Month"
                    android:textColor="#9CA3AF"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- NEW FEATURE: M-Pesa Message Paste Box -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Instant Verification"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>
                <EditText
                    android:id="@+id/etMpesaMessage"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginTop="10dp"
                    android:background="#33FFFFFF"
                    android:gravity="top|start"
                    android:hint="Paste M-Pesa Message Here..."
                    android:padding="10dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="14sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerifyPayment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="NOTIFY ADMIN NOW"
                    app:backgroundTint="#22C55E" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Original Contact Admin Button (Restored) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContactAdmin"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="10dp"
            android:text="SEND SCREENSHOT TO ADMIN"
            app:backgroundTint="#25D366"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>
