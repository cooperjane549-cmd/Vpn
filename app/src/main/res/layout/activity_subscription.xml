<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Premium Subscription"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#000000"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="24 Hours Access: Kes 30 / $0.25"
            android:gravity="center"
            android:textColor="#4CAF50"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#444444"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPayMpesa"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="PAY VIA M-PESA (TILL 3043489)"
                    android:backgroundTint="#FF0033"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPayPaypal"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="PAY VIA PAYPAL ($0.25)"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#FF0033"
                    app:cornerRadius="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paste Payment Proof Below:"
                    android:textColor="#BBBBBB"
                    android:layout_marginTop="20dp"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etMpesaMessage"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/rounded_edittext"
                    android:gravity="top|start"
                    android:hint="Paste M-Pesa SMS or PayPal Confirmation here..."
                    android:padding="12dp"
                    android:textColor="#000000"
                    android:textColorHint="#999999"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitPayment"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="20dp"
                    android:text="SUBMIT FOR APPROVAL"
                    android:backgroundTint="#2196F3"
                    android:textStyle="bold"
                    app:cornerRadius="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
