<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#090909">

    <!-- Status Text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DISCONNECTED"
        android:textColor="#9CA3AF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="60dp" />

    <!-- Balance Text (Updated to Mins to match your 24hr logic) -->
    <TextView
        android:id="@+id/tvMbBalance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 MIN"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <!-- NETWORK SELECTOR (Fixed IDs for Kevin/Sherwin logic) -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleNetworkGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:singleSelection="true"
        app:checkedButton="@+id/btnSafaricom"
        app:layout_constraintTop_toBottomOf="@id/tvMbBalance"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSafaricom"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kevin"
            android:textColor="#FFFFFF"
            app:strokeColor="#33FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAirtel"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sherwin"
            android:textColor="#FFFFFF"
            app:strokeColor="#33FFFFFF" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Main Connect Button (FIXED: Removed the 'Corner50' style causing the crash) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConnect"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:text="CONNECT"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="110dp"
        app:backgroundTint="#FF0033"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/toggleNetworkGroup"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/navTasks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TASKS"
            android:layout_marginEnd="10dp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1AFFFFFF"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="STORE"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1AFFFFFF"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
