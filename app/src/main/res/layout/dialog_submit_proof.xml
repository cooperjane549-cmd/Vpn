<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvDialogJobTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Job Title Here"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333" />

    <Button
        android:id="@+id/btnGoToLink"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="OPEN TASK LINK"
        android:layout_marginTop="15dp"
        android:backgroundTint="#2196F3" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Paste your proof (Username/Code):"
        android:layout_marginTop="15dp"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/etUserProof"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@android:drawable/editbox_background"
        android:gravity="top"
        android:padding="8dp"
        android:layout_marginTop="5dp"
        android:hint="e.g. My username is @user123" />

</LinearLayout>
