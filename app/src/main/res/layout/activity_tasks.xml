<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="30dp"
    android:gravity="center_horizontal"
    android:background="?android:attr/windowBackground">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FREE DAILY ACCESS"
        android:textAppearance="?attr/textAppearanceHeadline6"
        android:textColor="?attr/colorPrimary"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Watch 6 video ads to unlock 2 hours of unlimited browsing."
        android:textAlignment="center"
        android:layout_marginTop="12dp"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvAdProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Progress: 0 / 6"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="50dp"
        android:textColor="?attr/colorPrimary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnWatchAd"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="WATCH VIDEO AD"
        android:textSize="16sp"
        android:backgroundTint="?attr/colorPrimary"
        android:textColor="?attr/colorOnPrimary"
        android:layout_marginTop="40dp" />

    <TextView
        android:id="@+id/tvLimitMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You can claim this once every 24 hours."
        android:textSize="12sp"
        android:layout_marginTop="16dp"
        android:alpha="0.7"
        android:textColor="?android:attr/textColorSecondary" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Need more time? Visit the STORE for 24h access."
        android:textSize="13sp"
        android:textColor="?attr/colorPrimary"
        android:layout_marginBottom="10dp" />

</LinearLayout>
