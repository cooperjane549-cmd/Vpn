<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#090909">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:text="TASK MARKETPLACE"
            android:textColor="#FF0033"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#FF0033"
            app:cardCornerRadius="16dp">
            <LinearLayout
                android:padding="20dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView android:text="BOOST YOUR SOCIALS" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="16sp"/>
                <TextView android:text="Get 1,200+ followers or clicks for KSh 450" android:textColor="#FFCCCC" android:textSize="12sp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateTask"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="LAUNCH PAID TASK"
                    app:backgroundTint="#090909"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:text="EARN DATA"
            android:textColor="#9CA3AF"
            android:layout_marginTop="32dp"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="12dp">
            <LinearLayout
                android:padding="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:text="Watch Rewarded Ad" android:textColor="#FFFFFF" android:textStyle="bold"/>
                    <TextView android:text="+5 MB Credit" android:textColor="#22C55E" android:textSize="12sp"/>
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWatchAd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WATCH"
                    app:backgroundTint="#22C55E" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
